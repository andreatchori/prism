# Example environment for docker compose / local runs.
# Copy to .env and fill in values. Never commit real secrets.

PRISM_PORT=8080

# Global rules.toml (defaults for every repo)
# PRISM_CONFIG=config/examples/rules.toml
# Per-repo overlays directory (optional). Files named like github__owner__repo.toml
PRISM_REPOS_DIR=config/repos

# LLM provider selection: ollama (default) | openai | anthropic | azure-openai
# Can also be set in rules.toml [llm]; this env var overrides it.
PRISM_LLM_PROVIDER=ollama
PRISM_LLM_MAX_RETRIES=2
# Optional secondary provider used if the primary fails (e.g. cloud -> local)
PRISM_LLM_FALLBACK=

# Ollama (local, default)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder:6.7b
OLLAMA_TIMEOUT_SECONDS=120

# OpenAI (requires an OpenAI API plan; NOT a ChatGPT subscription)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=120

# Anthropic (requires an Anthropic API plan; NOT a Claude subscription)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_MAX_TOKENS=4096
# ANTHROPIC_TIMEOUT_SECONDS=120

# Azure OpenAI (model = deployment name, set via [llm].model or AZURE_OPENAI_DEPLOYMENT)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-06-01
# AZURE_OPENAI_TIMEOUT_SECONDS=120
# Max concurrent background reviews (optional)
PRISM_MAX_CONCURRENT_REVIEWS=4
# Logging (optional): format text|json, level debug|info|warn|error
PRISM_LOG_FORMAT=text
PRISM_LOG_LEVEL=info

GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
# Override for GitHub Enterprise (optional), e.g. https://ghe.example.com/api/v3
GITHUB_API_URL=https://api.github.com

GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_WEBHOOK_SECRET=

AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PAT=
AZURE_WEBHOOK_SECRET=

BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_TOKEN=
BITBUCKET_WEBHOOK_SECRET=

# Path to Rust rules CLI (prism check --json).
# Local: rust/target/release/prism.exe
# Docker image default: /app/bin/prism-engine
PRISM_ENGINE=
