# Example environment for docker compose / local runs.
# Copy to .env and fill in values. Never commit real secrets.

PRISM_PORT=8080
OLLAMA_MODEL=llama3.2
# Ollama call robustness (optional)
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=2
# Max concurrent background reviews (optional)
PRISM_MAX_CONCURRENT_REVIEWS=4

GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
# Override for GitHub Enterprise (optional), e.g. https://ghe.example.com/api/v3
GITHUB_API_URL=https://api.github.com

GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_WEBHOOK_SECRET=

AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PAT=
AZURE_WEBHOOK_SECRET=

BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_TOKEN=
BITBUCKET_WEBHOOK_SECRET=

# Optional path to Rust CLI binary (prism check --json)
# Example: rust/target/release/prism.exe
PRISM_ENGINE=
